<%-include("../../Views/Partials/user/header")%>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Heart Icon Styling */
  .heart-icon {
    font-size: 20px; 
    color: gray;
    transition: color 0.3s ease, transform 0.3s ease;
    position: relative;
    z-index: 5;
  }

  .heart-icon.active {
    color: red;
    transform: scale(1.1); /* Subtle pop effect */
  }

  /* Fireworks Container */
  .fireworks {
    position: absolute;
    top: 50%; /* Center vertically */
    left: 50%; /* Center horizontally */
    transform: translate(-50%, -50%); /* Perfect center */
    width: 60px;
    height: 60px;
    pointer-events: none;
    z-index: 1;
  }

  .firework-spark {
    position: absolute;
    width: 6px;
    height: 6px;
    background-color: gold; /* Golden spark */
    border-radius: 50%;
    opacity: 0;
    animation: explode 0.8s ease-out forwards;
  }

  .firework-spark:nth-child(even) {
    background-color: orange; /* Alternate color for variety */
  }

  @keyframes explode {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(var(--x), var(--y)) scale(0.5);
      opacity: 0;
    }
  }

  /*---------------------
    Hero
  -----------------------*/
  .primary-btn {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 14px 30px;
    color: #ffffff;
    background: #000000;
    letter-spacing: 4px;
  }

  .primary-btn i {
    margin-left: 14px;
    font-size: 12px;
    vertical-align: middle;
  }

  .hero__items {
    height: 800px;
    padding-top: 230px;
  }

  .hero__text h6 {
    color: #e53637;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 28px;
    position: relative;
    top: 0;
    opacity: 1;
    -webkit-transition: all, 0.3s;
    -o-transition: all, 0.3s;
    transition: all, 0.3s;
  }

  .hero__text h2 {
    color: #111111;
    font-size: 48px;
    font-weight: 500;
    line-height: 58px;
    margin-bottom: 30px;
    position: relative;
    top: 0;
    opacity: 1;
    -webkit-transition: all, 0.6s;
    -o-transition: all, 0.6s;
    transition: all, 0.6s;
  }

  .hero__text p {
    font-size: 16px;
    line-height: 28px;
    margin-bottom: 35px;
    position: relative;
    top: 0;
    opacity: 1;
    -webkit-transition: all, 0.9s;
    -o-transition: all, 0.9s;
    transition: all, 0.9s;
  }

  .hero__text .primary-btn {
    position: relative;
    top: 0;
    opacity: 1;
    -webkit-transition: all, 1.1s;
    -o-transition: all, 1.1s;
    transition: all, 1.1s;
  }

  @media (max-width: 767.98px) {
    .hero__items {
      height: auto;
      min-height: calc(100vh - 70px);
      padding-top: 156px;
      padding-bottom: 56px;
    }

    .hero__text h6 {
      margin-bottom: 16px;
    }

    .hero__text h2 {
      font-size: 36px;
      line-height: 44px;
      margin-bottom: 18px;
    }

    .hero__text p {
      margin-bottom: 22px;
    }

    .primary-btn {
      padding: 12px 22px;
      letter-spacing: 3px;
    }
  }

  .home_banner_area {
    margin-bottom: 85px !important;
  }

  @media (max-width: 767.98px) {
    .home_banner_area {
      margin-bottom: 40px !important;
    }
  }

  .feature_product_area .single-product .product-btm h4,
  .inspired_product_area .single-product .product-btm h4 {
    line-height: 18px;
    height: 36px;
    overflow: hidden;
    display: -webkit-box;
    line-clamp: 2;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>

<body>
  <!--================Home Banner Area =================-->
  <section class="home_banner_area mb-40">
    <div class="hero__slider">
      <div class="hero__items set-bg" data-setbg="img/hero/hero-1.jpg">
        <div class="container">
          <div class="row">
            <div class="col-xl-5 col-lg-7 col-md-8">
              <div class="hero__text">
                <h6>UrbanDot</h6>
                <h2>Wear the Difference Be the Standard.</h2>
                <p>Premium menswear thoughtfully crafted for the modern man. Timeless style that speaks before you do.</p>
                <a href="/shop" class="primary-btn">Shop now <i class="fa fa-arrow-right" aria-hidden="true"></i></a>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!--================End Home Banner Area =================-->

  <!-- Start feature Area -->
  <section class="feature-area section_gap_bottom_custom">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-3 col-md-6">
          <div class="single-feature">
            <a href="#" class="title">
              <i class="fa fa-tag" aria-hidden="true"></i>
              <h3>Best Price</h3>
            </a>
            <p>Quality fashion at the most competitive prices. Unbeatable value, every time.</p>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="single-feature">
            <a href="#" class="title">
              <i class="flaticon-truck"></i>
              <h3>Fast Shipping</h3>
            </a>
            <p>Orders dispatched within 24 hours. Quick and reliable delivery to your doorstep.</p>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="single-feature">
            <a href="#" class="title">
              <i class="flaticon-blockchain"></i>
              <h3>Secure payment</h3>
            </a>
            <p>Your payments are 100% encrypted and protected. Shop with complete confidence.</p>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="single-feature">
            <a href="#" class="title">
              <i class="flaticon-money"></i>
              <h3>Money back gurantee</h3>
            </a>
            <p>Not happy with your order? Get a full refund within 7 days, no questions asked.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- End feature Area -->

  <!--================ Feature Product Area =================-->
  <section class="feature_product_area section_gap_bottom_custom">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-12">
          <div class="main_title">
            <h2><span>New Arrivals</span></h2>
            <p>Fresh styles just landed. Shop the latest trends before they sell out.</p>
          </div>
        </div>
      </div>

      <div class="row">
        <% for(let i = 0; i < 3; i++){ %>
          <% let item = products[i]%>
          <div class="col-lg-4 col-md-6">
            <div class="single-product">
              <div class="product-img">
               <a href="/product/<%=item._id%>"><img class="img-fluid w-100" src="/uploads/product-images/<%= item.images[0] %>"/></a>
                <div class="p_icon">
                  <!-- <a href="#">
                    <i class="ti-eye"></i>
                  </a> -->
                  <a href="#" onclick="addToWishlist(`<%=item._id%>`, this, event)" class="wishlist-button">
                    <i class="ti-heart heart-icon"></i>
                    <div class="fireworks"></div>
                  </a>
                  <% if(item.stock !== 0){ %>
                    <a href="#" onclick="addToCart(`<%=item._id%>`)" class="addToCart-button">
                      <i class="ti-shopping-cart"></i>
                    </a>
                  <%}%>  
                </div>
              </div>
              <div class="product-btm">
                <a href="#" class="d-block">
                  <h4><%= item.productName%></h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">₹<%= item.regularPrice%></span>
                  <!-- <del>$<%= item.regularPrice%></del> -->
                </div>
              </div>
            </div>
          </div>
        <%} %>
      </div>
    </div>
  </section>
  <!--================ End Feature Product Area =================-->

  <!--================ Offer Area =================-->
  <section class="offer_area">
    <div class="container">
      <div class="row justify-content-center">
        <div class="offset-lg-4 col-lg-6 text-center">
          <div class="offer_content">
            <h3 class="text-uppercase mb-40">all men’s collection</h3>
            <h2 class="text-uppercase">50% off</h2>
            <a href="/shop" class="primary-btn mb-20 mt-5">Discover Now</a>
            <p>Limited Time Offer</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!--================ End Offer Area =================-->

  <!--================ Inspired Product Area =================-->
  <section class="inspired_product_area section_gap_bottom_custom">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-12">
          <div class="main_title">
            
          </div>
        </div>
      </div>

      <div class="row">
        <%for(let i = 2; i < 10; i++){ %>
            <% let item = products[i]%>
            <div class="col-lg-3 col-md-6">
              <div class="single-product">
                <div class="product-img">
                 <a href="/product/<%=item._id%>"><img class="img-fluid w-100" src="/uploads/product-images/<%= item.images[0] %>"/></a>
                  <div class="p_icon">
                    <!-- <a href="#">
                      <i class="ti-eye"></i>
                    </a> -->
                    <a href="#" onclick="addToWishlist(`<%=item._id%>`, this, event)" class="wishlist-button">
                      <i class="ti-heart heart-icon"></i>
                      <div class="fireworks"></div>
                    </a>
                    <% if(item.stock !== 0){ %>
                      <a href="#" onclick="addToCart(`<%=item._id%>`)" class="addToCart-button">
                        <i class="ti-shopping-cart"></i>
                      </a>
                    <%}%>  
                  </div>
                </div>
                <div class="product-btm">
                  <a href="#" class="d-block">
                    <h4><%= item.productName%></h4>
                  </a>
                  <div class="mt-3">
                    <% if(item.offerPrice !== null){ %>
                      <span class="mr-4">₹<%= item.offerPrice %></span>
                      <del>₹<%= item.regularPrice %></del>
                      <% 
                        const offerPercentage = Math.round(((item.regularPrice - item.offerPrice) / item.regularPrice) * 100); 
                      %>
                      <h5 style="color: #00b894;"><%= offerPercentage %>% off</h5>
                    <%}else{%>
                      <span class="mr-4">₹<%= item.regularPrice%></span>
                    <%}%>    
                  </div>
                </div>
              </div>
            </div>
        <%}%>
      </div>
    </div>
  </section>
  <!--================ End Inspired Product Area =================-->

  <script>
  async function addToWishlist(id, element, event) {
    try {
      let response = await fetch("/wishlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id }),
      });

      let data = await response.json();

      if (!data.success) {
        return Must.failure({ time: 3000, content: data.message })
      }

      // Heart Icon Animation
      const heartIcon = element.querySelector(".heart-icon");
      heartIcon.classList.add("active");

      // Fireworks Effect
      const fireworksContainer = element.querySelector(".fireworks");
      fireworksContainer.innerHTML = ""; 
      
      for (let i = 0; i < 15; i++) {
        const spark = document.createElement("div");
        spark.classList.add("firework-spark");

        // Randomize position
        const angle = Math.random() * 2 * Math.PI;
        const distance = Math.random() * 40 + 10; // Between 10px to 50px
        const x = Math.cos(angle) * distance;
        const y = Math.sin(angle) * distance;

        // Position spark
        spark.style.setProperty("--x", `${x}px`);
        spark.style.setProperty("--y", `${y}px`);

        fireworksContainer.appendChild(spark);
      }

      setTimeout(() => {
        heartIcon.classList.remove("active");
      }, 1000);

    } catch (error) {
      return Must.failure({ time: 3000, content: "Something went wrong" })
    }
  }

  async function addToCart(productId){
    let response = await fetch('/cart',{
      method : "POST",
      headers : {
        'Content-Type' : 'application/json'
      },
      body : JSON.stringify({ productId, quantity: 1 })
    })
    const data = await response.json()

    if (!data.status) {
      return Must.failure({ time: 3000, content: data.message })
    }

    Must.success({time: 1300, content: data.message, color:'#27ae60'})

    document.getElementById("icon").style.backgroundColor = 'beige'
    document.getElementsByClassName("pop-container")[0].style.borderRadius = '5px'

  }

</script>

<%-include("../../Views/Partials/user/footer")%>